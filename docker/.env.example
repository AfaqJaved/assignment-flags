# Optional overrides for docker/docker-compose.yml — every value already has a
# working default, so this file is only needed if you want to change one.
# Copy to docker/.env to have `docker compose` pick it up automatically.

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=flags
POSTGRES_PORT=5432

REDIS_PASSWORD=password
REDIS_PORT=6379

API_PORT=3000
ENABLE_API_DOCS=true
